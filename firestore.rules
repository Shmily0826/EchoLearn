rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User data: users/{uid}/data/{collection}
    // Only the authenticated owner can read/write their own data
    match /users/{userId}/data/{collection} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared AI analysis cache: aiAnalyses/{cacheKey}
    // Public-read (content is non-PII AI output of public transcripts) so the
    // cache is shared across all users; only authenticated users may write,
    // and only the expected shape (bounded content + timestamp).
    match /aiAnalyses/{docId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.content is string
        && request.resource.data.content.size() < 500000
        && request.resource.data.createdAt is int;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
