# EchoLearn — Environment Variables Template
# Copy this to .env.local and fill in your values. NEVER commit .env.local.

# ── Client-side (Vite exposes VITE_* to the browser) ──────────
# Firebase web config (public by design — security comes from Firestore Rules)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# (Optional) Custom YouTube CORS proxy base URL
VITE_YOUTUBE_PROXY=/api/yt?url=

# ── Server-side only (Vercel env vars, NOT prefixed with VITE_) ──
# These are set in Vercel Dashboard → Settings → Environment Variables
# DEEPSEEK_API_KEY=sk-xxx          (used by api/ai.ts)
# YOUTUBE_API_KEY=AIza-xxx         (used by api/youtube.ts)
